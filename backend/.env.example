DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=disciplinary_system
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d
PORT=5000

# Parent SMS notifications
# SMS is attempted automatically when a teacher creates a case for a student with linked parent records.
SMS_ENABLED=false

# Supported values: semaphore, twilio, philsms
SMS_PROVIDER=semaphore

# Semaphore
SMS_API_KEY=
SMS_SENDER_NAME=PTI
SMS_TEMPLATE_CASE_REPORT="Dear {parentName}, Philtech-GMA Disciplinary Alert: A new case ({caseNumber}) was reported for {studentName} regarding {violation} on {incidentDate}.{locationSentence} Please check the system or contact the school office for details."
SMS_TEMPLATE_HEARING_SCHEDULED="Dear {parentName}, Philtech-GMA Hearing Notice: A hearing for case {caseNumber} is scheduled on {scheduledDate} at {scheduledTime}.{locationSentence} Please check the portal for details."
SMS_TEMPLATE_HEARING_UPDATED="Dear {parentName}, Philtech-GMA {notificationTitle}: {notificationMessage}"
SMS_TEMPLATE_SANCTION_ASSIGNED="Dear {parentName}, Philtech-GMA Sanction Notice: A {sanctionType} sanction was assigned for case {caseNumber}.{startDateSentence}{endDateSentence}"
SMS_TEMPLATE_SANCTION_UPDATED="Dear {parentName}, Philtech-GMA Sanction Update: Case {caseNumber} sanction is now {status}.{startDateSentence}{endDateSentence}"

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# PhilSMS
PHILSMS_API_TOKEN=
PHILSMS_SENDER_ID=

# Student email notifications
# Emails are attempted when a student is reported, a hearing is scheduled/rescheduled, or a hearing is explicitly marked missed.
# Gmail setup: use a Google App Password, not your normal Gmail password.
EMAIL_ENABLED=false
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Philtech-GMA
SMTP_FROM_EMAIL=
FRONTEND_URL=http://127.0.0.1:5500/frontend/pages/auth/login.html
